generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth) ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role      @default(USER)
  stripeCustomerId String?   @unique

  // Invitation
  invitationToken   String?   @unique
  invitationExpires DateTime?

  // Préférences de notifications email
  notifNewCourses  Boolean   @default(true)
  notifEventReminders Boolean @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription          Subscription?
  purchases              Purchase[]
  progress               VideoProgress[]
  formationVideoProgress FormationVideoProgress[]
  eventRegistrations     EventRegistration[]
}

enum Role {
  USER
  ADMIN
}

model Course {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String  @db.Text
  thumbnail   String?
  videoUrl    String?
  duration    Int
  theme       String
  price                  Float?
  includedInSubscription Boolean @default(true)
  availableForRental     Boolean @default(true)
  isPublished            Boolean @default(false)
  sortOrder              Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases  Purchase[]
  progress   VideoProgress[]
}

model Formation {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String  @db.Text
  thumbnail   String?
  bookletUrl  String?
  price       Float?
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos    FormationVideo[]
  purchases Purchase[]
}

model FormationVideo {
  id          String  @id @default(cuid())
  formationId String
  title       String
  description String? @db.Text
  videoUrl    String?
  thumbnail   String?
  duration    Int     @default(0)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  formation Formation              @relation(fields: [formationId], references: [id], onDelete: Cascade)
  progress  FormationVideoProgress[]
}

model FormationVideoProgress {
  id               String   @id @default(cuid())
  userId           String
  formationVideoId String
  progress         Float    @default(0)
  completed        Boolean  @default(false)
  lastWatchedAt    DateTime @default(now())

  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  formationVideo FormationVideo @relation(fields: [formationVideoId], references: [id], onDelete: Cascade)

  @@unique([userId, formationVideoId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

model Purchase {
  id              String    @id @default(cuid())
  userId          String
  courseId         String?
  formationId     String?
  amount          Float
  stripePaymentId String
  expiresAt       DateTime? // Location 72h pour les cours (null = accès permanent, ex: formations)

  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  formation Formation? @relation(fields: [formationId], references: [id], onDelete: Cascade)
}

model VideoProgress {
  id            String   @id @default(cuid())
  userId        String
  courseId       String
  progress      Float    @default(0)
  completed     Boolean  @default(false)
  lastWatchedAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── Live Calendar Events ─────────────────────────────────────────

enum EventRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model LiveEvent {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String          @db.Text
  meetingLink     String
  startTime       DateTime
  duration        Int             // durée en minutes
  recurrence      EventRecurrence @default(NONE)
  recurrenceEnd   DateTime?
  maxParticipants Int             @default(20)
  isPublished     Boolean         @default(false)
  theme           String          @default("Général")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations EventRegistration[]
}

model EventRegistration {
  id             String    @id @default(cuid())
  userId         String
  eventId        String
  occurrenceDate DateTime
  cancelledAt    DateTime?

  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId, occurrenceDate])
}

// ─── CMS Content ───────────────────────────────────────────────────

model SiteContent {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  content   String  @db.Text
  rating    Int     @default(5)
  avatar    String?
  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String  @id @default(cuid())
  question  String
  answer    String  @db.Text
  sortOrder Int     @default(0)
  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Pricing Plans ─────────────────────────────────────────────────

model PricingPlan {
  id            String @id @default(cuid())
  slug          String @unique // "monthly" | "annual"
  name          String
  price         Float
  stripePriceId String
  interval      String // "month" | "year"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Stripe webhook idempotency ────────────────────────────────────

model StripeEvent {
  id        String   @id // Stripe event ID (evt_...)
  createdAt DateTime @default(now())
}
